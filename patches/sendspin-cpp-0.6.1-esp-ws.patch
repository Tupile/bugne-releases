@@ -49,6 +49,24 @@
 
 static const char* const TAG = "sendspin.ws_server";
 
+#ifdef CONFIG_HTTPD_WS_POST_HANDSHAKE_CB_SUPPORT
+// IDF (>=5.x) does NOT call the URI handler for the WebSocket handshake; it returns
+// after sending the 101 and offers this post-handshake callback instead. Fire
+// on_connected_cb here so the hub sends its client/hello once connected.
+static esp_err_t ws_post_handshake(httpd_req_t* req) {
+    int sockfd = httpd_req_to_sockfd(req);
+    auto* slot = static_cast<std::shared_ptr<SendspinServerConnection>*>(
+        httpd_sess_get_ctx(req->handle, sockfd));
+    if (slot != nullptr && *slot) {
+        SendspinServerConnection* conn = (*slot).get();
+        if (conn->on_connected_cb) {
+            conn->on_connected_cb(conn);
+        }
+    }
+    return ESP_OK;
+}
+#endif
+
 SendspinWsServer::~SendspinWsServer() {
     this->stop();
 }
